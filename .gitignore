# Credenciales, claves y estado sensible que nunca deben versionarse.
*.key
*.key.pem
*.keytab
*.p12
*.pfx
*.dump
*.secret
*.password
principal*
!kerberos/principals/
!kerberos/principals/**
stash
backups/

pki/private/*
!pki/private/.gitkeep

pki/certs/*
!pki/certs/.gitkeep

pki/csr/*
!pki/csr/.gitkeep

pki/ca/*
!pki/ca/.gitkeep

pki/openssl/*.tmp.cnf

kerberos/principals/keytabs/*
!kerberos/principals/keytabs/.gitkeep

results/raw/*
!results/raw/.gitkeep

results/experiments/*
!results/experiments/.gitkeep

results/faults/*
!results/faults/.gitkeep
