# consumidor replicacion ldap2

dn: olcDatabase={1}mdb,cn=config
changetype: modify
add: olcSyncrepl
olcSyncrepl: rid=002 provider=ldaps://ldap1.fis.epn.ec:636 bindmethod=simple binddn="uid=svc-replica,ou=services,dc=fis,dc=epn,dc=ec" credentials=REPLACE_WITH_PASSWORD searchbase="dc=fis,dc=epn,dc=ec" type=refreshAndPersist retry="5 5 300 +" timeout=1 tls_reqcert=demand
-
add: olcUpdateRef
olcUpdateRef: ldaps://ldap1.fis.epn.ec:636
